# Browser Automation Agent Configuration

# Target URL to automate
TARGET_URL="https://ui.shadcn.com/docs/forms/react-hook-form"

# Browser settings
HEADLESS="false"
BROWSER_CHANNEL="chromium"
VIEWPORT_WIDTH="1280"
VIEWPORT_HEIGHT="720"

# Timeouts (milliseconds)
NAVIGATION_TIMEOUT_MS="30000"
ELEMENT_TIMEOUT_MS="10000"
ACTION_TIMEOUT_MS="5000"

# Form values to fill
FORM_NAME="Test User"
FORM_DESCRIPTION="Automated description from browser agent"

# Logging
LOG_LEVEL="info"
LOG_TO_FILE="true"
LOG_DIR="./logs"

# Screenshots
SCREENSHOT_DIR="./screenshots"
SCREENSHOT_ON_FAILURE="true"
SCREENSHOT_ON_SUCCESS="true"

# Retry settings
MAX_RETRIES="3"
RETRY_BASE_DELAY_MS="1000"